# ──────────────────────────────────────────────────────────────
# NovelForge — environment configuration
# Copy this file to `.env` and fill in the values marked REQUIRED.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ===== Required =====
# Secret used to sign JWTs. Use a long, random string.
SECRET_KEY=change-me-to-a-long-random-string
# Your LLM API key (OpenAI or any OpenAI-compatible provider).
OPENAI_API_KEY=sk-your-api-key-here

# ===== Core app =====
ENVIRONMENT=production
DEBUG=false
LOGGING_LEVEL=INFO
APP_PORT=8080
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ===== Database =====
# "sqlite" (zero-config, default) or "mysql".
DB_PROVIDER=sqlite
SQLITE_DB_PATH=storage/novelforge.db
# Used only when DB_PROVIDER=mysql
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=novelforge
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=novelforge
MYSQL_ROOT_PASSWORD=change-me-root

# ===== LLM =====
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o-mini
# Number of candidate drafts generated per chapter.
WRITER_CHAPTER_VERSION_COUNT=2

# ===== Embeddings (RAG retrieval) =====
EMBEDDING_PROVIDER=openai            # "openai" or "ollama"
EMBEDDING_BASE_URL=                  # falls back to OPENAI_API_BASE_URL
EMBEDDING_API_KEY=                   # falls back to OPENAI_API_KEY
EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_MODEL_VECTOR_SIZE=3072   # set to match your model, or leave unset to auto-detect
OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# ===== Vector store (libsql) =====
VECTOR_DB_URL=file:./storage/rag_vectors.db
VECTOR_DB_AUTH_TOKEN=
VECTOR_TOP_K_CHUNKS=5
VECTOR_TOP_K_SUMMARIES=3
VECTOR_CHUNK_SIZE=480
VECTOR_CHUNK_OVERLAP=120

# ===== Bootstrap admin (created on first launch) =====
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=ChangeMe123!
ADMIN_DEFAULT_EMAIL=admin@example.com

# ===== Registration & email (optional) =====
ALLOW_USER_REGISTRATION=false        # set true to open self-service sign-up
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=
EMAIL_FROM=NovelForge
